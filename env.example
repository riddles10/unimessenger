# ============================================================
# PIPSIGHT MESSENGER — ENVIRONMENT VARIABLES
# Fill in all values before running the server.
# Never commit this file to git.
# ============================================================


# ------------------------------------------------------------
# BIRD API (MessageBird)
# Get these from: https://app.bird.com → Settings → Credentials
# ------------------------------------------------------------

# Your Bird access key (looks like: "sk_live_xxxx")
BIRD_ACCESS_KEY=

# Your Bird workspace ID (found in the URL: app.bird.com/workspaces/<THIS_ID>)
BIRD_WORKSPACE_ID=

# Channel IDs are found in: Bird Dashboard → Channels → click the channel → copy its ID
BIRD_WHATSAPP_CHANNEL_ID=
BIRD_TELEGRAM_CHANNEL_ID=


# ------------------------------------------------------------
# GEMINI (Google AI)
# Get from: https://aistudio.google.com/app/apikey
# Reuse the same key already in your Pipsight .env
# ------------------------------------------------------------

GEMINI_API_KEY=


# ------------------------------------------------------------
# SUPABASE
# Get from: https://supabase.com → your project → Settings → API
# Reuse the same project as Pipsight — do NOT create a new one
# ------------------------------------------------------------

# Project URL (looks like: https://xxxx.supabase.co)
SUPABASE_URL=

# Use the service_role key (NOT the anon key) — it bypasses RLS for backend use
SUPABASE_SERVICE_ROLE_KEY=


# ------------------------------------------------------------
# REDIS (for BullMQ job queue)
# Option A — Local: install Redis and leave the default below
# Option B — Managed: use Upstash (https://upstash.com) → copy the Redis URL
# ------------------------------------------------------------

REDIS_URL=redis://localhost:6379


# ------------------------------------------------------------
# SERVER
# Port the Express backend listens on
# ------------------------------------------------------------

PORT=4000


# ------------------------------------------------------------
# TELEGRAM BOT (optional during early dev)
# Create a bot at: https://t.me/BotFather → /newbot
# Needed to generate the t.me deep-link shown at Pipsight registration
# Bird handles the webhook automatically once the channel is configured
# ------------------------------------------------------------

# Your bot's username without the @ (e.g. PipsightBot)
TELEGRAM_BOT_USERNAME=


# ------------------------------------------------------------
# WEBHOOK (Bird inbound messages)
# Bird needs a publicly accessible URL to POST events to.
# During local dev, use ngrok: https://ngrok.com
#   1. Run: ngrok http 4000
#   2. Copy the https URL it gives you
#   3. In Bird Dashboard → Conversations → Webhooks, set:
#      URL: https://<your-ngrok-id>.ngrok-free.app/webhook/bird
# In production, replace with your deployed server URL.
# ------------------------------------------------------------

# Full public URL of this server (no trailing slash)
# e.g. https://abc123.ngrok-free.app  OR  https://api.yourdomain.com
PUBLIC_URL=
